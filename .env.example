# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=recipient@example.com
EMAIL_FROM=your-email@gmail.com

# NWS Configuration
NWS_STATION=KMDT
